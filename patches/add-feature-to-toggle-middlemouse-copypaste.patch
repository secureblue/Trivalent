 VIEWS_EXPORT BASE_DECLARE_FEATURE(kKeyboardAccessibleTooltipInViews);
 VIEWS_EXPORT BASE_DECLARE_FEATURE(kApplyInitialUrlToWebContents);

+VIEWS_EXPORT BASE_DECLARE_FEATURE(kMiddleClickCopyPaste);
