 SANDBOX_EXPORT bpf_dsl::ResultExpr RestrictMemfdCreate() {
   const Arg<int> flags(1);
   return If((flags & ~(MFD_CLOEXEC | MFD_ALLOW_SEALING)) == 0, Allow())
