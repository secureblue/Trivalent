       # implementation with a few custom glibc patches. Use that if it's
@@ -3363,8 +3379,14 @@ buildflag_header("compiler_buildflags") {
 }
 
 config("cet_shadow_stack") {
-  if (enable_cet_shadow_stack && is_win) {
+  if (enable_cet_shadow_stack) {
