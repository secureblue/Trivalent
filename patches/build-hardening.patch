         # The strong variant of the stack protector significantly increases
@@ -400,6 +409,13 @@ config("compiler") {
       }
     }
 
+    if (is_linux) {
+      cflags += [ "-fstack-clash-protection" ]
+
+      cflags += [ "-mharden-sls=all" ]
+      rustflags += [ "-Ctarget-feature=+harden-sls-ijmp", "-Ctarget-feature=+harden-sls-ret" ]
+    }
+
     if (use_lld) {
       ldflags += [ "-fuse-ld=lld" ]
       if (lld_path != "") {
@@ -2282,7 +2298,7 @@ config("chromium_code") {
